# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/formguard
# Or individual parts:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=formguard
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend URL (for CORS) ─────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Invite Links ────────────────────────────────────────
# Base URL for employee invite links
APP_BASE_URL=http://localhost:5173
INVITE_TOKEN_EXPIRES_HOURS=72

# ─── Encryption (for SSN / sensitive fields) ─────────────
ENCRYPTION_KEY=32_char_hex_key_change_in_production_!!

# ─── Dropbox Sign (HelloSign) ────────────────────────────────
DROPBOX_SIGN_API_KEY=your_dropbox_sign_api_key
DROPBOX_SIGN_CLIENT_ID=your_client_id_for_embedded_signing
DROPBOX_SIGN_W4_TEMPLATE_ID=
DROPBOX_SIGN_I9_TEMPLATE_ID=

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com

# ─── AI (Claude API) ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
